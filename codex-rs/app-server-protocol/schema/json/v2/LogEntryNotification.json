{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "LogEntryLevel": {
      "enum": [
        "trace",
        "debug",
        "info",
        "warn",
        "error"
      ],
      "type": "string"
    },
    "LogSpanContext": {
      "properties": {
        "fields": {
          "additionalProperties": true,
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "fields",
        "name"
      ],
      "type": "object"
    }
  },
  "properties": {
    "fields": {
      "additionalProperties": true,
      "type": "object"
    },
    "level": {
      "$ref": "#/definitions/LogEntryLevel"
    },
    "message": {
      "type": "string"
    },
    "span": {
      "anyOf": [
        {
          "$ref": "#/definitions/LogSpanContext"
        },
        {
          "type": "null"
        }
      ]
    },
    "target": {
      "type": "string"
    },
    "timestamp": {
      "format": "int64",
      "type": "integer"
    }
  },
  "required": [
    "fields",
    "level",
    "message",
    "target",
    "timestamp"
  ],
  "title": "LogEntryNotification",
  "type": "object"
}