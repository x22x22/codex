{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AbsolutePathBuf": {
      "description": "A path that is guaranteed to be absolute and normalized (though it is not guaranteed to be canonicalized or exist on the filesystem).\n\nIMPORTANT: When deserializing an `AbsolutePathBuf`, a base path must be set using [AbsolutePathBufGuard::new]. If no base path is set, the deserialization will fail unless the path being deserialized is already absolute.",
      "type": "string"
    },
    "AdditionalFileSystemPermissions": {
      "properties": {
        "read": {
          "items": {
            "$ref": "#/definitions/AbsolutePathBuf"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "write": {
          "items": {
            "$ref": "#/definitions/AbsolutePathBuf"
          },
          "type": [
            "array",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "AdditionalNetworkPermissions": {
      "properties": {
        "enabled": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "AdditionalPermissionProfile": {
      "properties": {
        "fileSystem": {
          "anyOf": [
            {
              "$ref": "#/definitions/AdditionalFileSystemPermissions"
            },
            {
              "type": "null"
            }
          ]
        },
        "network": {
          "anyOf": [
            {
              "$ref": "#/definitions/AdditionalNetworkPermissions"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "type": "object"
    },
    "GrantedPermissionProfile": {
      "properties": {
        "fileSystem": {
          "anyOf": [
            {
              "$ref": "#/definitions/AdditionalFileSystemPermissions"
            },
            {
              "type": "null"
            }
          ]
        },
        "network": {
          "anyOf": [
            {
              "$ref": "#/definitions/AdditionalNetworkPermissions"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "type": "object"
    },
    "PermissionGrantScope": {
      "oneOf": [
        {
          "properties": {
            "type": {
              "enum": [
                "turn"
              ],
              "title": "TurnPermissionGrantScopeType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "TurnPermissionGrantScope",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "enum": [
                "session"
              ],
              "title": "SessionPermissionGrantScopeType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "SessionPermissionGrantScope",
          "type": "object"
        },
        {
          "properties": {
            "permissionProfileAmendment": {
              "$ref": "#/definitions/PermissionProfileAmendment"
            },
            "type": {
              "enum": [
                "persist"
              ],
              "title": "PersistPermissionGrantScopeType",
              "type": "string"
            }
          },
          "required": [
            "permissionProfileAmendment",
            "type"
          ],
          "title": "PersistPermissionGrantScope",
          "type": "object"
        }
      ]
    },
    "PermissionProfileAmendment": {
      "properties": {
        "permissions": {
          "$ref": "#/definitions/AdditionalPermissionProfile"
        },
        "profileName": {
          "type": "string"
        }
      },
      "required": [
        "permissions",
        "profileName"
      ],
      "type": "object"
    }
  },
  "properties": {
    "permissions": {
      "$ref": "#/definitions/GrantedPermissionProfile"
    },
    "scope": {
      "allOf": [
        {
          "$ref": "#/definitions/PermissionGrantScope"
        }
      ],
      "default": {
        "type": "turn"
      }
    }
  },
  "required": [
    "permissions"
  ],
  "title": "PermissionsRequestApprovalResponse",
  "type": "object"
}